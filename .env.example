# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Postgres — asyncpg driver is added automatically if you use postgresql://
DATABASE_URL=postgresql://user:password@localhost:5432/agora

# JWT — must be >=32 chars; app refuses to start in production without this
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256

# Token TTLs
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# development | production
# In production: JWT_SECRET and DATABASE_URL are required; Secure cookie is set
ENV=development
