# Optional overrides for docker compose. With no .env at all, the stack uses
# safe defaults:
#   - POSTGRES_USER=agora, POSTGRES_PASSWORD=agora_local, POSTGRES_DB=agora
#   - JWT_SECRET: auto-generated on first start, persisted in the `api_data` volume
#   - OPENROUTER_API_KEY: empty — users add their own keys in Account settings
#   - Caddy on http://localhost:8080
#
# Copy this file to .env only if you want to override any of the above. The
# stack works out of the box without any of these set.

# ---- Postgres (used by the `db` service AND interpolated into DATABASE_URL) --
POSTGRES_USER=agora
# IMPORTANT: change this before exposing the DB port to any network other than
# localhost. The default is fine for a private local stack with no open ports.
POSTGRES_PASSWORD=agora_local
POSTGRES_DB=agora

# In-network DSN the `api` service uses to reach Postgres. Hostname `db` is the
# compose service name. Keep credentials in sync with the three vars above.
DATABASE_URL=postgresql://agora:agora_local@db:5432/agora

# ---- API auth / runtime -----------------------------------------------------
# Optional. If unset, the container auto-generates a 64-char secret and persists
# it to /data/jwt_secret in the api_data volume. Tokens from one run will be
# valid on the next as long as the volume is preserved.
# To set explicitly: openssl rand -hex 32
# JWT_SECRET=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=30

# Optional. Users set their own keys in Account settings. This env var is a
# fallback used when a user has no personal key set. The app starts and accounts
# work without it — only AI calls will fail for users who haven't added a key.
OPENROUTER_API_KEY=

# Allowed browser origins for CORS. Default matches the Caddy mapping below.
# If you change PUBLIC_ORIGIN, change this too.
CORS_ORIGINS=http://localhost:8080

# development | production. The auto-secret behavior works in both modes.
# Defaults to production in docker-compose.yml since the auto-secret means
# we can stay strict without forcing setup.
ENV=production

# ---- Frontend ---------------------------------------------------------------
# Public URL the browser uses. Must match what Caddy serves. SvelteKit's Node
# adapter rejects POST form actions that don't match this origin.
PUBLIC_ORIGIN=http://localhost:8080
